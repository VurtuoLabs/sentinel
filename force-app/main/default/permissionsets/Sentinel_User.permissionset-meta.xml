<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Sentinel User</label>
    <description>Everything needed to run Sentinel: Apex actions, flows, the dashboard app/tab, and read/write on the watched standard objects. Assign to end users and to the agent's running user.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- App + tab -->
    <applicationVisibilities>
        <application>Sentinel</application>
        <visible>true</visible>
    </applicationVisibilities>
    <tabSettings>
        <tab>Sentinel_Dashboard</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Apex classes (invocables, service, controller, monitor) -->
    <classAccesses>
        <apexClass>SentinelService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelHealthCheck</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelRollupAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelReassignAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelFollowUpAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelDashboardController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelCatalogAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelMonitor</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- Flow-fronted action targets -->
    <flowAccesses>
        <flow>Sentinel_HealthCheck</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_Rollup</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_Reassign</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_CreateFollowUp</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_Catalog</flow>
        <enabled>true</enabled>
    </flowAccesses>

    <!-- Watched objects: read to surface, edit to reassign, create Task for follow-ups -->
    <objectPermissions>
        <object>Opportunity</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Case</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Lead</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Task</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
</PermissionSet>
