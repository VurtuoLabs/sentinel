<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Sentinel User</label>
    <description>Everything needed to run Sentinel: Apex actions, flows, the dashboard app/tab, and read/write on the watched standard objects. Assign to end users and to the agent's running user.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- App + tab -->
    <applicationVisibilities>
        <application>Sentinel</application>
        <visible>true</visible>
    </applicationVisibilities>
    <tabSettings>
        <tab>Sentinel_Dashboard</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Sentinel_Trends</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Sentinel_Leaderboard</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Sentinel_Snoozed</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Sentinel_PipelineValue</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Sentinel_SingleThreaded</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Sentinel_ActivityGaps</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Apex classes (invocables, service, controller, monitor) -->
    <classAccesses>
        <apexClass>SentinelService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelHealthCheck</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelRollupAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelReassignAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelFollowUpAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelDashboardController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelCatalogAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelMonitor</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelSnoozeAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelLogActivityAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelWhatChangedAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelAccountContextAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SentinelTeamRollupAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- Flow-fronted action targets -->
    <flowAccesses>
        <flow>Sentinel_HealthCheck</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_Rollup</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_Reassign</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_CreateFollowUp</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_Catalog</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_Snooze</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_LogActivity</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_WhatChanged</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_AccountContext</flow>
        <enabled>true</enabled>
    </flowAccesses>
    <flowAccesses>
        <flow>Sentinel_TeamRollup</flow>
        <enabled>true</enabled>
    </flowAccesses>

    <!-- Watched objects: read to surface, edit to reassign, create Task for follow-ups -->
    <objectPermissions>
        <object>Opportunity</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Case</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Lead</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Task</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Account</object>
        <allowRead>true</allowRead>
        <allowEdit>false</allowEdit>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>OpportunityContactRole</object>
        <allowRead>true</allowRead>
        <allowEdit>false</allowEdit>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- Sentinel-owned support objects: snooze state and daily trend snapshots -->
    <objectPermissions>
        <object>Sentinel_Snooze__c</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Sentinel_Snapshot__c</object>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>

    <!-- Required fields (Record_Id__c, Object_API_Name__c, Snoozed_Until__c, Snapshot_Date__c) are
         universally required and cannot carry explicit FLS entries; access is implicit. -->
    <fieldPermissions>
        <field>Sentinel_Snooze__c.Reason__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Sentinel_Snooze__c.Snoozed_By__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Sentinel_Snapshot__c.Label__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Sentinel_Snapshot__c.Stale_Count__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Sentinel_Snapshot__c.Critical_Count__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
</PermissionSet>
