<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Sentinel_WhatChanged</fullName>
    <label>Sentinel What Changed</label>
    <description>Flow-fronted wrapper over SentinelWhatChangedAction. Compares today's at-risk counts to the most recent Sentinel_Snapshot__c row. Holds no logic of its own.</description>
    <processType>AutoLaunchedFlow</processType>
    <apiVersion>65.0</apiVersion>
    <status>Active</status>

    <variables>
        <name>objectApiName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>

    <variables>
        <name>deltaJson</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>message</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
    </variables>

    <actionCalls>
        <name>Run_What_Changed</name>
        <label>Run What Changed</label>
        <locationX>176</locationX>
        <locationY>158</locationY>
        <actionName>SentinelWhatChangedAction</actionName>
        <actionType>apex</actionType>
        <inputParameters>
            <name>objectApiName</name>
            <value>
                <elementReference>objectApiName</elementReference>
            </value>
        </inputParameters>
        <outputParameters>
            <assignToReference>deltaJson</assignToReference>
            <name>deltaJson</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>message</assignToReference>
            <name>message</name>
        </outputParameters>
    </actionCalls>

    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Run_What_Changed</targetReference>
        </connector>
    </start>
</Flow>
